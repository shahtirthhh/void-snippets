{
  "name": "@void-snippets/react",
  "version": "0.2.1",
  "description": "TanStack Query resource hooks factory for React",
  "homepage": "https://github.com/shahtirthhh/void-snippets",
  "repository": {
    "type": "git",
    "url": "https://github.com/shahtirthhh/void-snippets.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/shahtirthhh/void-snippets/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "keywords": [
    "react",
    "tanstack-query",
    "react-query",
    "hooks",
    "api",
    "void-snippets"
  ],
  "license": "MIT",
  "peerDependencies": {
    "react": ">=17.0.0",
    "@void-snippets/client": ">=0.1.0"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.0.0",
    "@void-snippets/core": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "react": "^18.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
