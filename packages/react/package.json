{
  "name": "@void-snippets/react",
  "version": "0.6.0",
  "description": "TanStack Query resource hooks factory, Socket.IO hooks factory, type-safe routing contract, and general-purpose React hooks",
  "homepage": "https://github.com/shahtirthhh/void-snippets",
  "repository": {
    "type": "git",
    "url": "https://github.com/shahtirthhh/void-snippets.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/shahtirthhh/void-snippets/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.mjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "keywords": [
    "react",
    "tanstack-query",
    "react-query",
    "hooks",
    "api",
    "socket.io",
    "websocket",
    "routing",
    "react-router",
    "type-safe",
    "void-snippets",
    "createResourceHooks",
    "createSocketHooks",
    "createRouteContract",
    "useTypedSearchParams",
    "useModal",
    "usePagination",
    "useAsyncState",
    "useAlertMessage",
    "useCallTimer"
  ],
  "license": "MIT",
  "peerDependencies": {
    "react": ">=17.0.0",
    "@void-snippets/client": ">=0.1.0",
    "socket.io-client": ">=4.6.0",
    "react-router": ">=7.0.0"
  },
  "peerDependenciesMeta": {
    "socket.io-client": {
      "optional": true
    },
    "react-router": {
      "optional": true
    }
  },
  "dependencies": {
    "@tanstack/react-query": "^5.0.0",
    "@void-snippets/core": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "react": "^18.0.0",
    "react-router": "^7.0.0",
    "socket.io-client": "^4.7.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
