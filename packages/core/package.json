{
  "name": "@void-snippets/core",
  "version": "0.3.0",
  "description": "Core types and utilities for void-snippets packages",
  "homepage": "https://github.com/shahtirthhh/void-snippets",
  "repository": {
    "type": "git",
    "url": "https://github.com/shahtirthhh/void-snippets.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/shahtirthhh/void-snippets/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.mjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "keywords": ["typescript", "void-snippets", "types"],
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
