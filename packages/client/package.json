{
  "name": "@void-snippets/client",
  "version": "0.3.0",
  "description": "Framework-agnostic HTTP resource service for TypeScript projects",
  "homepage": "https://github.com/shahtirthhh/void-snippets",
  "repository": {
    "type": "git",
    "url": "https://github.com/shahtirthhh/void-snippets.git",
    "directory": "packages/client"
  },
  "bugs": {
    "url": "https://github.com/shahtirthhh/void-snippets/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.mjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "keywords": ["axios", "typescript", "api", "void-snippets", "resource"],
  "license": "MIT",
  "dependencies": {
    "@void-snippets/core": "workspace:*",
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
